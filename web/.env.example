# PostgreSQL connection string
# Build from ~/.config/dev-ai-neon-connection-params:
#   postgresql://{PGUSER}:{PGPASSWORD_URL_ENCODED}@{PGHOST}:{PGPORT}/{PGDATABASE}?sslmode=require
DATABASE_URL=postgresql://postgres.dgombmvvlzyvglazljvm:REPLACE_PASSWORD@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres?sslmode=require

# NextAuth secret — generate with: openssl rand -base64 32
AUTH_SECRET=REPLACE_ME

# Resend API key for magic link emails (https://resend.com)
AUTH_RESEND_KEY=re_REPLACE_ME

# From address (must be from a verified Resend domain)
EMAIL_FROM=dev-ai <noreply@yourdomain.com>

# Public URL of the deployed app (set automatically on Vercel)
# AUTH_URL=https://your-app.vercel.app
